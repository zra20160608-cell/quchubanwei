# 去除班味 - 生产环境配置
# 部署前请替换所有 <...> 占位符

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=3000

# ==================== 数据库配置 (阿里云RDS) ====================
DB_HOST=banwei-prod.pg.rds.aliyuncs.com
DB_PORT=5432
DB_USER=banwei_prod
DB_PASSWORD=<your-rds-password>
DB_NAME=banwei
# RDS SSL CA证书路径（可选，生产环境建议启用）
DB_SSL_CA=/path/to/rds-ca.pem

# ==================== Redis配置 (阿里云Redis) ====================
REDIS_HOST=banwei-prod.redis.rds.aliyuncs.com
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# ==================== JWT配置 ====================
# 生产环境必须使用强随机密钥！
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<your-strong-jwt-secret>
JWT_EXPIRES_IN=2h

# ==================== 微信小程序配置 ====================
WECHAT_APPID=<your-wechat-appid>
WECHAT_SECRET=<your-wechat-secret>

# ==================== 阿里云OSS配置 ====================
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=banwei-oss
OSS_ACCESS_KEY_ID=<your-access-key-id>
OSS_ACCESS_KEY_SECRET=<your-access-key-secret>
# OSS自定义域名（CDN加速）
OSS_CUSTOM_DOMAIN=https://cdn.banwei.app

# ==================== AI服务配置 ====================
# 图像识别API
AI_VISION_API_KEY=<your-vision-api-key>
AI_VISION_ENDPOINT=<your-vision-endpoint>

# 文本生成API（辣评生成）
AI_TEXT_API_KEY=<your-text-api-key>
AI_TEXT_ENDPOINT=<your-text-endpoint>
AI_TEXT_MODEL=gpt-4o-mini

# ==================== 内容审核配置 ====================
# 阿里云内容安全
CONTENT_SECURITY_ACCESS_KEY=<your-security-access-key>
CONTENT_SECURITY_SECRET=<your-security-secret>
CONTENT_SECURITY_REGION=cn-hangzhou

# ==================== 日志配置 ====================
# 日志级别：debug, info, warn, error
LOG_LEVEL=info
LOG_DIR=/home/banwei/logs
# 是否输出JSON格式日志（生产环境建议开启）
LOG_JSON=true

# ==================== 性能配置 ====================
# 请求超时（毫秒）
REQUEST_TIMEOUT=30000
# 文件上传大小限制（字节）
UPLOAD_MAX_SIZE=10485760
# 并发请求限制
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ==================== 监控配置 ====================
# 阿里云ARMS
ARMS_LICENSE_KEY=<your-arms-license-key>
ARMS_APP_NAME=banwei-backend

# ==================== 通知配置 ====================
# 钉钉机器人（告警通知）
DINGTALK_WEBHOOK=<your-dingtalk-webhook>
DINGTALK_SECRET=<your-dingtalk-secret>

# ==================== 备份配置 ====================
# 数据库备份目录
BACKUP_DIR=/home/banwei/backups
# OSS备份 bucket
BACKUP_OSS_BUCKET=banwei-backups
